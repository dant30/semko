# ============================================================================
# Application Identity
# ============================================================================
VITE_APP_NAME=SEMKO IMS

# ============================================================================
# API Configuration
# ============================================================================
# For development: Use relative path; Vite proxy will forward to backend
VITE_API_BASE_URL=/api

# For production (built/deployed): Use absolute URL of your API server
# Example production settings:
# VITE_API_BASE_URL=https://api.semko.co.ke/api/v1
# VITE_API_BASE_URL=https://www.semko.co.ke/api/v1

# ============================================================================
# Backend URL (Development Proxy Configuration)
# ============================================================================
# Used by vite.config.ts to proxy API requests during `npm run dev`
# (not used in production builds)
VITE_BACKEND_URL=http://127.0.0.1:8000

# ============================================================================
# Optional: Environment Mode
# ============================================================================
# NODE_ENV=development  # or "production" for production build

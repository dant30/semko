# ============================================================================
# Django Core
# ============================================================================
# REQUIRED: Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# User Registration & Features
# ============================================================================
ALLOW_PUBLIC_REGISTRATION=True

# ============================================================================
# Trip Document Management
# ============================================================================
TRIP_DOCUMENT_MAX_UPLOAD_MB=10
TRIP_DOCUMENT_ALLOWED_TYPES=.pdf,.jpg,.jpeg,.png,.txt
TRIP_DOCUMENTS_EXPOSE_DIRECT_URLS=False

# ============================================================================
# CORS Configuration (Frontend Origin)
# ============================================================================
# Development (default if not set)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Production:
# CORS_ALLOWED_ORIGINS=https://www.semko.co.ke,https://semko.co.ke

# ============================================================================
# Database
# ============================================================================
DB_NAME=semko
DB_USER=semko
DB_PASSWORD=7777
DB_HOST=db
DB_PORT=5432

# Alternative: Use DATABASE_URL for deployment platforms (Heroku, Render, Railway)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ============================================================================
# Email Configuration
# ============================================================================
DEFAULT_FROM_EMAIL=noreply@semko.local
# Example Gmail SMTP:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# SMS Configuration
# ============================================================================
SMS_SENDER_ID=SEMKO

# ============================================================================
# Redis (Celery & Caching)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0

# ============================================================================
# Logging
# ============================================================================
# Set to DEBUG for verbose logs; INFO for production
DJANGO_LOG_LEVEL=INFO
